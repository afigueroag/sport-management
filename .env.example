# Aplicación
APP_NAME=SportAcademia
APP_VERSION=0.1.0
DEBUG=False

# Base de Datos
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sport_management_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost", "http://localhost:8000", "http://localhost:3000"]

# Email (para Phase 2+)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Stripe (para Phase 6)
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Azure SQL (si usas Azure en lugar de local PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@server.database.windows.net:5432/database_name?sslmode=require
