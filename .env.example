# Application
APP_NAME=SportAcademia
APP_VERSION=0.1.0
DEBUG=False

# Database (Local Development - will be overridden in Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sport_academy
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sport_academy

# JWT & Security
SECRET_KEY=change-this-to-a-very-long-random-string-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost", "http://localhost:8000", "http://localhost:3000"]

# Email (for future use)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Stripe Payment Integration
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Production Notes:
# 1. Change SECRET_KEY to a random string (at least 32 characters)
# 2. Use strong database password (20+ characters, mix of types)
# 3. Set DEBUG=False in production
# 4. Update CORS_ORIGINS to your domain
# 5. Get real Stripe keys from production dashboard
# 6. Use environment variables via Docker secrets or .env file in secure location
